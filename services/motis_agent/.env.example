# Runtime mode
RUNTIME_MODE=standalone

# Local standalone state
LOCAL_STATE_DIR=.motis
STANDALONE_USER_ID=00000000-0000-4000-8000-000000000001
STANDALONE_USER_EMAIL=standalone@motis.local

# Platform/dev database only
DATABASE_URL=postgresql+asyncpg://motis:motis@localhost:5432/motis

# MCP bridge
DATA_MCP_URL=http://localhost:8002
AGENT_MCP_SECRET=dev-secret-change-in-prod

# Optional tool backends
BRAVE_API_KEY=
TAVILY_API_KEY=

# Optional CLI defaults for OpenAI-compatible providers
MOTIS_MODEL=gpt-5.3-codex
MOTIS_BASE_URL=https://api.openai.com/v1
MOTIS_API_KEY=
MOTIS_REFERENCE_MODELS=

# Optional filesystem overrides
# OPERATORS_PATH=.motis/operators
# SKILLS_PATH=.motis/skills

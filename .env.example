# Shared workspace settings for Motis.
# For agent-only local defaults, see: services/motis_agent/.env.example

# ─── Agent Runtime ───────────────────────────────────────────────────────────
# See: docs/operators/05-configuration-guide.md
#   dev        -> checked-in operators/skills under services/motis_agent/
#   platform   -> multi-user database-backed runtime
#   standalone -> local state under services/motis_agent/.motis or LOCAL_STATE_DIR
RUNTIME_MODE=dev
LOCAL_STATE_DIR=services/motis_agent/.motis
STANDALONE_USER_ID=00000000-0000-4000-8000-000000000001
STANDALONE_USER_EMAIL=standalone@motis.local

# ─── Model Defaults ──────────────────────────────────────────────────────────
MOTIS_BASE_URL=https://api.openai.com/v1
MOTIS_MODEL=gpt-4o
MOTIS_API_KEY=
MOTIS_REFERENCE_MODELS=

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://motis:motis@localhost:5432/motis

# ─── MCP Bridge ──────────────────────────────────────────────────────────────
AGENT_MCP_SECRET=dev-secret-change-in-prod
MCP_URL=http://localhost:8002
# DATA_MCP_URL=http://localhost:8002
# EXECUTION_MCP_URL=http://localhost:8002
# OPERATOR_MCP_URL=http://localhost:8002

# ─── Optional Tool Backends ─────────────────────────────────────────────────
BRAVE_API_KEY=
TAVILY_API_KEY=
TUSHARE_TOKEN=

# ─── Terminal Sandbox ───────────────────────────────────────────────────────
TERMINAL_BACKEND=subprocess
TERMINAL_TIMEOUT_SECONDS=30

# ─── Platform Risk Guard ────────────────────────────────────────────────────
PLATFORM_MAX_LEVERAGE=20
PLATFORM_MAX_POSITION_PCT=25
PLATFORM_MAX_DAILY_LOSS_PCT=15
PLATFORM_MAX_ORDER_USD=100000

# ─── Runtime Mode ────────────────────────────────────────────────────────────
# Controls where operators and skills are loaded from.
# "dev"        → filesystem (services/agent/motis_agent/operators/)
# "platform"   → PostgreSQL (multi-user, per user_id)
# "standalone"  → filesystem (~/.motis/operators/)
# See: docs/operators/05-configuration-guide.md
RUNTIME_MODE=dev

# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://motis:motis@localhost:5432/motis
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET=your-jwt-secret-min-32-chars
JWT_ALGORITHM=HS256

# ─── Encryption (for user API keys at rest) ──────────────────────────────────
ENCRYPTION_KEY=your-32-byte-fernet-key-base64

# ─── Platform default model (users can override with BYOM) ───────────────────
DEFAULT_MODEL_BASE_URL=https://openrouter.ai/api/v1
DEFAULT_MODEL_API_KEY=your-openrouter-key
DEFAULT_MODEL_NAME=anthropic/claude-sonnet-4-5

# ─── Finance Data Sources (all optional — auto-fallback if missing) ───────────
TUSHARE_TOKEN=
CCXT_DEFAULT_EXCHANGE=binance

# ─── Exchange Connectivity (platform-level, for paper trade infra) ────────────
# Note: user exchange keys are stored encrypted in DB, not here
HYPERLIQUID_TESTNET=true

# ─── Storage ─────────────────────────────────────────────────────────────────
S3_BUCKET=motis-artifacts
S3_ENDPOINT_URL=https://your-r2-endpoint.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# ─── Billing ─────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
MARKETPLACE_FEE_PERCENT=20

# ─── Services (internal, Docker network) ─────────────────────────────────────
AGENT_SERVICE_URL=http://agent:8001
MCP_SERVICE_URL=http://mcp:8002
PLATFORM_API_URL=http://platform:8000

# ─── Celery (Operator Runtime) ────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ─── Feature Flags ────────────────────────────────────────────────────────────
ENABLE_LIVE_TRADING=false
ENABLE_MARKETPLACE=false
ENABLE_ARENA=false
